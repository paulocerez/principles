# Sanity project — required for fetching articles at build time and for the embedded Studio.
# Get these from https://sanity.io after creating a project.
VITE_SANITY_PROJECT_ID=your_project_id
VITE_SANITY_DATASET=production

# Optional: read token (only needed if you want to query draft/private content during build).
# For published content the public read API works without a token.
# SANITY_READ_TOKEN=
